-- ============================================================
-- AUTO FARM + AUTO PATROL UNTUK GAME ROLEPLAY PERBATASAN
-- Versi: 1.0
-- Cara pakai: Jalankan di executor, lalu GUI akan muncul.
-- ============================================================

local player = game:GetService("Players").LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

local isFarming = false
local isPatrol = false
local farmTask = nil
local patrolTask = nil

-- ============================================================
-- KONFIGURASI KOORDINAT (SESUAIKAN DENGAN GAME KAMU!)
-- ============================================================
local CONFIG = {
    -- Koordinat untuk Auto Farm
    blackMarket = Vector3.new(0, 0, 0),    -- Tempat beli barang
    border = Vector3.new(50, 0, 0),        -- Perbatasan (checkpoint)
    sellPoint = Vector3.new(100, 0, 0),    -- Tempat jual di sisi US
    mexicoSpawn = Vector3.new(-50, 0, 0),  -- Kembali ke Mexico

    -- Koordinat untuk Auto Patrol (titik-titik patroli)
    patrolPoints = {
        Vector3.new(-20, 0, 0),
        Vector3.new(20, 0, 0),
        Vector3.new(0, 0, 20),
        Vector3.new(0, 0, -20),
    },

    -- Delay antar aksi (detik)
    farmDelay = 2,
    patrolDelay = 3,
}

-- ============================================================
-- FUNGSI DASAR
-- ============================================================
local function moveTo(position)
    if not rootPart or not humanoid then return end
    humanoid:MoveTo(position)
    -- Tunggu sampai sampai (max 15 detik)
    local timeout = 0
    while (rootPart.Position - position).Magnitude > 5 and timeout < 150 do
        task.wait(0.1)
        timeout = timeout + 1
    end
    task.wait(0.5)
end

local function teleportTo(position)
    if not rootPart then return end
    rootPart.CFrame = CFrame.new(position)
    task.wait(0.3)
end

local function pressE()
    -- Simulasi tekan E untuk interaksi
    local VirtualUser = game:GetService("VirtualUser")
    if VirtualUser then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new(0, 0))
    else
        -- Alternatif: kirim key event (kurang reliable)
        game:GetService("VirtualInputManager"):SendKeyEvent(true, "E", false, game)
        task.wait(0.1)
        game:GetService("VirtualInputManager"):SendKeyEvent(false, "E", false, game)
    end
    task.wait(0.4)
end

-- ============================================================
-- AUTO FARM
-- ============================================================
local function startFarming()
    if isFarming then return end
    isFarming = true
    print("[Auto Farm] Started!")

    farmTask = task.spawn(function()
        while isFarming do
            -- 1. Pergi ke Black Market (beli barang)
            moveTo(CONFIG.blackMarket)
            pressE()  -- Interaksi beli
            task.wait(CONFIG.farmDelay)

            -- 2. Pergi ke perbatasan
            moveTo(CONFIG.border)
            pressE()  -- Melewati perbatasan
            task.wait(CONFIG.farmDelay)

            -- 3. Pergi ke tempat jual
            moveTo(CONFIG.sellPoint)
            pressE()  -- Jual barang
            task.wait(CONFIG.farmDelay)

            -- 4. Kembali ke sisi Mexico
            moveTo(CONFIG.mexicoSpawn)
            task.wait(CONFIG.farmDelay)
        end
    end)
end

local function stopFarming()
    if isFarming then
        isFarming = false
        if farmTask then
            task.cancel(farmTask)
            farmTask = nil
        end
        print("[Auto Farm] Stopped!")
    end
end

-- ============================================================
-- AUTO PATROL
-- ============================================================
local patrolIndex = 1
local function startPatrol()
    if isPatrol then return end
    if #CONFIG.patrolPoints < 2 then
        print("⚠️ Patrol points minimal 2!")
        return
    end
    isPatrol = true
    patrolIndex = 1
    print("[Auto Patrol] Started!")

    patrolTask = task.spawn(function()
        while isPatrol do
            local target = CONFIG.patrolPoints[patrolIndex]
            moveTo(target)
            patrolIndex = patrolIndex % #CONFIG.patrolPoints + 1
            task.wait(CONFIG.patrolDelay)
        end
    end)
end

local function stopPatrol()
    if isPatrol then
        isPatrol = false
        if patrolTask then
            task.cancel(patrolTask)
            patrolTask = nil
        end
        print("[Auto Patrol] Stopped!")
    end
end

-- ============================================================
-- FUNGSI UNTUK MEREKAM POSISI (TAMBAHAN)
-- ============================================================
local recordingPoints = {}
local isRecording = false
local recordTask = nil

local function startRecording()
    if isRecording then return end
    recordingPoints = {}
    isRecording = true
    print("[Recording] Started! Tekan R untuk rekam posisi, tekan S untuk stop.")

    recordTask = task.spawn(function()
        while isRecording do
            task.wait(0.5)
        end
    end)
end

local function stopRecording()
    if isRecording then
        isRecording = false
        if recordTask then
            task.cancel(recordTask)
            recordTask = nil
        end
        print("[Recording] Stopped! Total points:", #recordingPoints)
        -- Tampilkan koordinat yang direkam
        for i, pos in ipairs(recordingPoints) do
            print(string.format("Point %d: (%.1f, %.1f, %.1f)", i, pos.X, pos.Y, pos.Z))
        end
    end
end

local function addCurrentPosition()
    if not rootPart then return end
    local pos = rootPart.Position
    table.insert(recordingPoints, pos)
    print("✅ Point added:", pos)
end

-- ============================================================
-- KEYBIND (UNTUK REKAM POSISI)
-- ============================================================
local UserInputService = game:GetService("UserInputService")

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    local key = input.KeyCode.Name

    if key == "R" and isRecording then
        addCurrentPosition()
    elseif key == "S" and isRecording then
        stopRecording()
        -- Set patrol points dari hasil rekaman jika ada
        if #recordingPoints > 1 then
            CONFIG.patrolPoints = recordingPoints
            print("✅ Patrol points updated from recording!")
        end
    end
end)

